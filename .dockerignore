# Exclude deploy/ noise from the build context, but keep the docker build inputs
# the Dockerfiles COPY (deploy/local/* and the shared deploy/package/*). The
# droplet lane and the env tooling stay out of the local image context.
/deploy/*
!/deploy/local
!/deploy/package
!/deploy/droplet
